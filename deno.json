{
  "name": "@dep/yaml-layer",
  "version": "1.3.1",
  "exports": {
    ".": "./src/mod.ts",
    "./cli": "./src/cli.ts",
    "./config": "./src/core/config.ts"
  },
  "compilerOptions": {
    "strict": true
  },
  "imports": {
    "@/": "./src/",
    "@dep/command": "jsr:@dep/command@^3.0.0",
    "@dep/path": "jsr:@dep/path@^1.0.0",
    "@dep/schema": "jsr:@dep/schema@^1.0.2",
    "@dep/yaml-layer/generated": "./.yaml-layer/generated/main.ts",
    "@dep/cache": "jsr:@dep/cache@^1.0.0",
    "@dep/slug": "jsr:@dep/slug@^1.1.0",
    "@std/fmt": "jsr:@std/fmt@^1.0.10",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/yaml": "jsr:@std/yaml@^1.1.0"
  },
  "tasks": {
    "start": "deno run --allow-all src/main.ts",
    "build": "deno run --allow-all src/cli.ts build",
    "dev": "deno run --allow-all src/cli.ts watch",
    "check-types": "deno check src/**/*.ts && deno publish --check",
    "docs": "lineo md 'src/**/*.ts' --outFile code.md --outDir temp",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "clean": "rm -rf .yaml-layer",
    "pack": "deno compile -A -o yaml-layer ./src/cli.ts",
    "prerelease": "deno lint && deno fmt",
    "release": "deno task prerelease && jsr publish ./"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "exclude": ["README.md"],
    "useTabs": false,
    "lineWidth": 80,
    "indentWidth": 2,
    "singleQuote": true,
    "semiColons": true,
    "trailingCommas": "onlyMultiLine"
  }
}
